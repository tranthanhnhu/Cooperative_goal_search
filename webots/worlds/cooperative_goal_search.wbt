Robot {
  name "R3"
  translation 1.25 0.05 -1.25
  controller "cooperative_goal_search"
  children [
    GPS { name "gps" }
    Compass { name "compass" }
    Shape {
      appearance Appearance { material Material { diffuseColor 1 0.6 0 } }
      geometry Cylinder { radius 0.05 height 0.04 }
    }
    HingeJoint {
      device [ RotationalMotor { name "left wheel motor" } ]
      endPoint Solid {
        name "left_R3"
        translation -0.05 0 0
        children [
          Shape {
            appearance Appearance { material Material { diffuseColor 0.1 0.1 0.1 } }
            geometry Cylinder { radius 0.02 height 0.01 }
          }
        ]
      }
    }
    HingeJoint {
      device [ RotationalMotor { name "right wheel motor" } ]
      endPoint Solid {
        name "right_R3"
        translation 0.05 0 0
        children [
          Shape {
            appearance Appearance { material Material { diffuseColor 0.1 0.1 0.1 } }
            geometry Cylinder { radius 0.02 height 0.01 }
          }
